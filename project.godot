; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pokepai"
config/description="2D Pokemon Go adventure"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
PokemonDB="*res://scripts/autoload/pokemon_db.gd"
MoveData="*res://scripts/data/move_data.gd"
EventTracker="*res://scripts/autoload/event_tracker.gd"
StoryEvents="*res://scripts/data/story_events.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="viewport"
window/stretch/aspect="expand"

